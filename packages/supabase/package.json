{
  "name": "@eventdex/supabase",
  "version": "0.0.0",
  "description": "Clientes Supabase compartidos entre apps (server, browser, público y service-role)",
  "private": true,
  "type": "module",
  "exports": {
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./browser": {
      "types": "./src/browser.ts",
      "default": "./src/browser.ts"
    },
    "./public": {
      "types": "./src/public.ts",
      "default": "./src/public.ts"
    },
    "./service": {
      "types": "./src/service.ts",
      "default": "./src/service.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@eventdex/database": "workspace:*",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.2"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
