---
import { Card, CardContent } from "@/components/starwind/card";
import { Icon } from "astro-icon/components";
import Layout from "@/layouts/Layout.astro";
---
<Layout title="Lo de Charly TCG - 2026">
  <section class="flex-1 min-h-[calc(100vh-4rem)] max-w-4xl mx-auto flex flex-col items-center justify-center px-2 py-8">
    <Card size="sm" class="mx-4">
      <CardContent class="flex items-center gap-2">
        <Icon name="pixelarticons:clock" class="text-muted-foreground size-5" />
        <span class="text-xl text-accent">20 y 21 de Enero · 10:00 a 20:00</span>
      </CardContent>
    </Card>

    <Card class="highlight z-10">
      <CardContent class="font-press-start-2p text-center space-y-1 px-2">
        <h1 class="text-2xl text-secondary uppercase text-balance">Lo de Charly TCG</h1>
        <p class="text-xs text-muted-foreground text-pretty">Recorré los locales del evento, descubrí cartas únicas y participá de la experiencia interactiva recolectando una medallas.</p>
      </CardContent>
    </Card>

    <Card size="sm" class="mx-4">
      <CardContent>
        <h3 class="text-xl text-accent">Centro de convenciones Ciudad Paleta</h3>
        <p class="text-muted-foreground">Av. Pokemon 151, Ciudad Paleta</p>
      </CardContent>
    </Card>
  </section>
</Layout>
